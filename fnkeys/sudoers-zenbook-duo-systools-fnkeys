# Allow zenbook-duo-systools-fnkeys to control the detachable keyboard and mirrored display backlight without a password.
Cmnd_Alias ZENBOOK_DUO_FNKEYS_BACKLIGHT = /usr/bin/python3 /usr/lib/zenbook-duo-fnkeys/backlight.py *
Cmnd_Alias ZENBOOK_DUO_FNKEYS_BRIGHTNESS = /usr/bin/tee /sys/class/backlight/*/brightness, /usr/bin/tee /sys/class/leds/*/brightness
ALL ALL=(root) NOPASSWD: ZENBOOK_DUO_FNKEYS_BACKLIGHT, ZENBOOK_DUO_FNKEYS_BRIGHTNESS
