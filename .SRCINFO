pkgbase = zenbook-duo-systools
	pkgdesc = System tools for Asus Zenbook Duo: keyboard backlight, display layout, and power profile
	pkgver = 1.0.0
	pkgrel = 1
	install = src/zenbook-duo-systools.install
	arch = x86_64
	arch = aarch64
	license = custom
	depends = bash
	depends = sudo
	depends = kscreen
	depends = power-profiles-daemon
	optdepends = libnotify: notify-send notifications
	optdepends = networkmanager: nmcli (optional)
	backup = etc/zenbook-duo/duo.conf
