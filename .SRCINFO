	source = zenbook-duo-systools.sleep::file:///home/maz/zenbook-duo-linux/src/zenbook-duo-systools.sleep
	source = sudoers-zenbook-duo-systools::file:///home/maz/zenbook-duo-linux/src/sudoers-zenbook-duo-systools
	source = zenbook-duo-systools.install::file:///home/maz/zenbook-duo-linux/src/zenbook-duo-systools.install
